rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128;
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isBootstrapAdmin() {
      return isSignedIn() && (
        request.auth.token.email == 'rashmae26@gmail.com' || 
        request.auth.token.email == 'rashmaeansay@gmail.com'
      );
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    // ===============================================================
    // ENTITY VALIDATORS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'idNumber', 'role']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.idNumber is string && data.idNumber.size() > 0 && data.idNumber.size() <= 50 &&
             data.role in ['student', 'admin'] &&
             (data.get('yearLevel', '') is string) &&
             (data.get('email', '') is string) &&
             (data.get('photoURL', '') is string) &&
             (data.keys().contains('lastLogin') ? data.lastLogin is timestamp : true);
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['progressMap', 'updatedAt']) &&
             data.progressMap is map &&
             data.updatedAt == request.time;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'subjectId', 'userId', 'userName', 'type', 'url', 'isPublic', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 255 &&
             data.subjectId is string &&
             data.userName is string &&
             data.type is string &&
             data.url is string &&
             data.isPublic is bool &&
             data.createdAt == request.time;
    }

    function isValidRating(data) {
      return data.keys().hasAll(['subjectId', 'userId', 'userName', 'rating', 'createdAt']) &&
             data.subjectId is string &&
             (data.userId == request.auth.uid || isAdmin()) &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    function isValidQuestion(data) {
      return data.keys().hasAll(['title', 'userId', 'createdAt']) &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 255 &&
             data.userId == request.auth.uid &&
             (data.get('userName', '') is string) &&
             (data.get('content', '') is string) &&
             (data.get('subjectTag', '') is string) &&
             (data.get('votes', 0) is number) &&
             (data.get('answerCount', 0) is number) &&
             (data.get('isFlagged', false) is bool) &&
             (data.get('reportCount', 0) is number) &&
             (data.keys().contains('latestAnswer') ? data.latestAnswer is map : true) &&
             data.createdAt == request.time;
    }

    function isValidStudyGroup(data) {
      return data.keys().hasAll(['name', 'subjectCode', 'creatorId']) &&
             data.name is string && data.name.size() > 0 && data.name.size() <= 100 &&
             data.subjectCode is string &&
             data.creatorId is string &&
             (data.get('description', '') is string) &&
             (data.get('members', []) is list) &&
             (data.keys().contains('createdAt') ? data.createdAt == request.time : true);
    }

    function isValidNotification(data) {
      return data.keys().hasAll(['userId', 'title', 'message', 'type', 'read', 'createdAt']) &&
             data.userId is string &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 255 &&
             data.message is string && data.message.size() <= 1000 &&
             data.type in ['info', 'success', 'warning', 'error', 'announcement'] &&
             data.read is bool &&
             (request.method == 'create' ? data.createdAt == request.time : true);
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    match /test/connection {
      allow read: if true;
    }

    match /notifications/{notificationId} {
      allow read, list: if isSignedIn() && resource.data.userId == request.auth.uid;
      allow create: if isEmailVerified() && (isAdmin() || incoming().userId == request.auth.uid); // Temporarily allow user to create for demo/testing
      allow update: if isSignedIn() && existing().userId == request.auth.uid && 
                       incoming().diff(existing()).affectedKeys().hasOnly(['read']);
      allow delete: if isSignedIn() && existing().userId == request.auth.uid;
    }

    match /studyGroups/{groupId} {
      allow read, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(groupId) && isValidStudyGroup(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          // Allow joining (adding members)
          (incoming().diff(existing()).affectedKeys().hasOnly(['members']) && isValidStudyGroup(incoming())) ||
          // Allow creator to edit
          (existing().creatorId == request.auth.uid && isValidStudyGroup(incoming()))
        )
      );
      allow delete: if isEmailVerified() && (existing().creatorId == request.auth.uid || isAdmin());

      match /messages/{messageId} {
        allow read, list: if isSignedIn() && (
          get(/databases/$(database)/documents/studyGroups/$(groupId)).data.members.hasAny([request.auth.uid]) ||
          get(/databases/$(database)/documents/studyGroups/$(groupId)).data.creatorId == request.auth.uid ||
          isAdmin()
        );
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
      }
    }

    match /questions/{questionId} {
      allow read, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(questionId) && isValidQuestion(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          // Allow voting and answering for all verified users
          (incoming().diff(existing()).affectedKeys().hasOnly(['votes', 'answerCount', 'latestAnswer', 'isFlagged', 'reportCount']) && isValidQuestion(incoming())) ||
          // Allow owner to edit content
          (existing().userId == request.auth.uid && isValidQuestion(incoming()))
        )
      );
      allow delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isEmailVerified() && isValidId(userId) && isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (incoming().role == 'student' || isBootstrapAdmin());
      
      allow update: if isEmailVerified() && isValidId(userId) && (
        isAdmin() || (
          isOwner(userId) && 
          isValidUser(incoming()) &&
          (incoming().role == existing().role || isBootstrapAdmin()) &&
          incoming().diff(existing()).affectedKeys().hasOnly([
            'fullName', 'idNumber', 'yearLevel', 'lastLogin', 'email', 'photoURL', 'progress', 'role', 'uid'
          ])
        )
      );
    }

    match /userProgress/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isEmailVerified() && isOwner(userId) && isValidUserProgress(incoming());
    }

    match /ratings/{ratingId} {
      allow read, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(ratingId) && isValidRating(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          existing().userId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'feedback', 'userName', 'likes', 'likedBy']) &&
          isValidRating(incoming())
        )
      );
      allow delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /resources/{resourceId} {
      allow read: if isSignedIn() && (existing().isPublic == true || existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(resourceId) && isValidResource(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          existing().userId == request.auth.uid &&
          isValidResource(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'isPublic', 'type', 'url', 'fileName'])
        )
      );
      allow delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    match /notebooks/{notebookId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(notebookId) && incoming().userId == request.auth.uid;
      allow update, delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());

      match /sources/{sourceId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
        allow update, delete: if isEmailVerified() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
      }
    }

    match /flashcardDecks/{deckId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(deckId) && incoming().userId == request.auth.uid;
      allow update, delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());

      match /cards/{cardId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/flashcardDecks/$(deckId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
        allow update, delete: if isEmailVerified() && (get(/databases/$(database)/documents/flashcardDecks/$(deckId)).data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
