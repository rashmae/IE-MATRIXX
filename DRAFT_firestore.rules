rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // DEFAULT DENY
    // ===============================================================
    match /{document=**} {
      allow read, write: if false;
    }

    // ===============================================================
    // HELPER FUNCTIONS
    // ===============================================================
    
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isEmailVerified() {
      return isSignedIn() && request.auth.token.email_verified == true;
    }
    
    function isOwner(userId) {
      return isSignedIn() && request.auth.uid == userId;
    }
    
    function isValidId(id) {
      return id is string && id.size() > 0 && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }
    
    function incoming() {
      return request.resource.data;
    }
    
    function existing() {
      return resource.data;
    }

    function isBootstrapAdmin() {
      return request.auth.token.email in ['rashmae26@gmail.com', 'rashmaeansay@gmail.com'];
    }

    function isAdmin() {
      return isSignedIn() && (
        isBootstrapAdmin() ||
        (exists(/databases/$(database)/documents/users/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/users/$(request.auth.uid)).data.get('role', 'student') == 'admin')
      );
    }

    // ===============================================================
    // ENTITY VALIDATORS
    // ===============================================================

    function isValidUser(data) {
      return data.keys().hasAll(['uid', 'fullName', 'idNumber', 'role']) &&
             data.uid == request.auth.uid &&
             data.fullName is string && data.fullName.size() > 0 && data.fullName.size() <= 100 &&
             data.idNumber is string && data.idNumber.size() > 0 && data.idNumber.size() <= 50 &&
             data.role in ['student', 'admin'] &&
             (data.get('yearLevel', '') is string) &&
             (data.get('email', '') is string) &&
             (data.get('photoURL', '') is string) &&
             (data.keys().contains('lastLogin') ? data.lastLogin is timestamp : true);
    }

    function isValidUserProgress(data) {
      return data.keys().hasAll(['progressMap', 'updatedAt']) &&
             data.progressMap is map &&
             data.updatedAt == request.time;
    }

    function isValidResource(data) {
      return data.keys().hasAll(['title', 'subjectId', 'userId', 'userName', 'type', 'url', 'isPublic', 'createdAt']) &&
             data.userId == request.auth.uid &&
             data.title is string && data.title.size() > 0 && data.title.size() <= 255 &&
             data.subjectId is string &&
             data.userName is string &&
             data.type is string &&
             data.url is string &&
             data.isPublic is bool &&
             data.createdAt == request.time;
    }

    function isValidRating(data) {
      return data.keys().hasAll(['subjectId', 'userId', 'userName', 'rating', 'createdAt']) &&
             data.subjectId is string &&
             data.userId == request.auth.uid &&
             data.userName is string &&
             data.rating is number && data.rating >= 1 && data.rating <= 5 &&
             data.createdAt == request.time;
    }

    // ===============================================================
    // COLLECTION RULES
    // ===============================================================

    // Connection Test
    match /test/connection {
      allow read: if true;
    }

    // Subjects (Admin-only write)
    match /subjects/{subjectId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Users
    match /users/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      
      allow create: if isEmailVerified() && isValidId(userId) && isOwner(userId) && 
                      isValidUser(incoming()) && 
                      (incoming().role == 'student' || isBootstrapAdmin());
      
      allow update: if isEmailVerified() && isValidId(userId) && (
        isAdmin() || (
          isOwner(userId) && 
          isValidUser(incoming()) &&
          incoming().role == existing().role && // Prevent self-elevation
          incoming().diff(existing()).affectedKeys().hasOnly([
            'fullName', 'idNumber', 'yearLevel', 'lastLogin', 'email', 'photoURL', 'progress'
          ])
        )
      );
    }

    // User Progress (Legacy/Alternative storage)
    match /userProgress/{userId} {
      allow read: if isSignedIn() && (isOwner(userId) || isAdmin());
      allow write: if isEmailVerified() && isOwner(userId) && isValidUserProgress(incoming());
    }

    // Ratings
    match /ratings/{ratingId} {
      allow read, list: if isSignedIn();
      allow create: if isEmailVerified() && isValidId(ratingId) && isValidRating(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          existing().userId == request.auth.uid &&
          incoming().diff(existing()).affectedKeys().hasOnly(['rating', 'feedback', 'userName']) &&
          isValidRating(incoming())
        )
      );
      allow delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Resources
    match /resources/{resourceId} {
      allow read: if isSignedIn() && (existing().isPublic == true || existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(resourceId) && isValidResource(incoming());
      allow update: if isEmailVerified() && (
        isAdmin() || (
          existing().userId == request.auth.uid &&
          isValidResource(incoming()) &&
          incoming().diff(existing()).affectedKeys().hasOnly(['title', 'isPublic', 'type', 'url'])
        )
      );
      allow delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());
    }

    // Announcements
    match /announcements/{annId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }

    // Calendar Events
    match /calendarEvents/{eventId} {
      allow read: if isSignedIn();
      allow write: if isAdmin();
    }
    
    // Notebooks
    match /notebooks/{notebookId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(notebookId) && incoming().userId == request.auth.uid;
      allow update, delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());

      match /sources/{sourceId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
        allow update, delete: if isEmailVerified() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
      }

      match /messages/{messageId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/notebooks/$(notebookId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
      }
    }

    // Flashcard Decks
    match /flashcardDecks/{deckId} {
      allow read: if isSignedIn() && (existing().userId == request.auth.uid || isAdmin());
      allow create: if isEmailVerified() && isValidId(deckId) && incoming().userId == request.auth.uid;
      allow update, delete: if isEmailVerified() && (existing().userId == request.auth.uid || isAdmin());

      match /cards/{cardId} {
        allow read: if isSignedIn() && (get(/databases/$(database)/documents/flashcardDecks/$(deckId)).data.userId == request.auth.uid || isAdmin());
        allow create: if isEmailVerified() && incoming().userId == request.auth.uid;
        allow update, delete: if isEmailVerified() && (get(/databases/$(database)/documents/flashcardDecks/$(deckId)).data.userId == request.auth.uid || isAdmin());
      }
    }
  }
}
