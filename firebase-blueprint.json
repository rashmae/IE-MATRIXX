{
  "entities": {
    "User": {
      "title": "User",
      "description": "A student or admin user of the IE Matrix system.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "Firebase Auth UID" },
        "fullName": { "type": "string", "description": "Full name of the student" },
        "idNumber": { "type": "string", "description": "CTU Student ID Number" },
        "email": { "type": "string", "description": "Email address" },
        "yearLevel": { "type": "string", "enum": ["1st Year", "2nd Year", "3rd Year", "4th Year", "Graduate"], "description": "Current year level of the student" },
        "role": { "type": "string", "enum": ["student", "admin"], "description": "User role" },
        "lastLogin": { "type": "string", "format": "date-time", "description": "Last login timestamp" },
        "progress": { "type": "object", "description": "Subject completion status map" }
      },
      "required": ["uid", "fullName", "idNumber", "role"]
    },
    "SubjectRating": {
      "title": "Subject Rating",
      "description": "A student's rating and feedback for a specific subject.",
      "type": "object",
      "properties": {
        "subjectId": { "type": "string", "description": "ID of the subject being rated" },
        "userId": { "type": "string", "description": "UID of the student" },
        "userName": { "type": "string", "description": "Name of the student" },
        "rating": { "type": "number", "description": "Star rating (1-5)" },
        "feedback": { "type": "string", "description": "Optional text feedback" },
        "createdAt": { "type": "string", "format": "date-time", "description": "When the rating was submitted" }
      },
      "required": ["subjectId", "userId", "rating", "createdAt"]
    },
    "StudyGroup": {
      "title": "Study Group",
      "description": "A collaborative group centered around a subject.",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "subjectCode": { "type": "string" },
        "members": { "type": "array", "items": { "type": "string" } },
        "creatorId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "subjectCode", "creatorId"]
    },
    "Question": {
      "title": "Forum Question",
      "description": "A peer Q&A post.",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "content": { "type": "string" },
        "userId": { "type": "string" },
        "userName": { "type": "string" },
        "subjectTag": { "type": "string" },
        "votes": { "type": "number" },
        "answerCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "userId", "createdAt"]
    },
    "Notebook": {
      "title": "Notebook",
      "description": "A collection of sources and chat history for specific study contexts.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "summary": { "type": "string", "description": "AI generated summary of the notebook" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "NotebookSource": {
      "title": "Notebook Source",
      "description": "An individual resource (text, link, or file) imported into a notebook.",
      "type": "object",
      "properties": {
        "notebookId": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["file", "link", "text"] },
        "content": { "type": "string", "description": "Extracted text content for AI processing" },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["notebookId", "userId", "title", "type", "content", "createdAt"]
    },
    "NotebookMessage": {
      "title": "Notebook Message",
      "description": "A chat message within a notebook's AI conversation.",
      "type": "object",
      "properties": {
        "notebookId": { "type": "string" },
        "userId": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "assistant"] },
        "content": { "type": "string" },
        "citations": { "type": "array", "items": { "type": "string" }, "description": "Source IDs referenced in the response" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["notebookId", "userId", "role", "content", "createdAt"]
    },
    "Subject": {
      "title": "Subject",
      "description": "An academic subject in the Industrial Engineering curriculum.",
      "type": "object",
      "properties": {
        "subjectCode": { "type": "string" },
        "subjectName": { "type": "string" },
        "units": { "type": "number" },
        "yearLevel": { "type": "string", "enum": ["1st Year", "2nd Year", "3rd Year", "4th Year"] },
        "semester": { "type": "string", "enum": ["1st Sem", "2nd Sem", "Summer"] },
        "courseDescription": { "type": "string" },
        "prerequisites": { "type": "array", "items": { "type": "string" } },
        "instructor": { "type": "string" },
        "courseOutcomes": { "type": "array", "items": { "type": "string" } },
        "topics": { "type": "array", "items": { "type": "string" } },
        "syllabusURL": { "type": "string" },
        "isAvailable": { "type": "boolean" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["subjectCode", "subjectName"]
    },
    "FlashcardDeck": {
      "title": "Flashcard Deck",
      "description": "A collection of flashcards for a specific subject or topic.",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "name": { "type": "string" },
        "description": { "type": "string" },
        "subjectId": { "type": "string" },
        "color": { "type": "string" },
        "cardCount": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" },
        "updatedAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "name", "createdAt"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "An individual flashcard with front and back content.",
      "type": "object",
      "properties": {
        "deckId": { "type": "string" },
        "userId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "status": { "type": "string", "enum": ["learning", "known"], "description": "Study status for the card" },
        "interval": { "type": "number", "description": "Interval in days until next review" },
        "easeFactor": { "type": "number", "description": "Ease factor for the card (SM-2 algorithm)" },
        "repetitions": { "type": "number", "description": "Number of successful repetitions" },
        "nextReview": { "type": "string", "format": "date-time" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deckId", "userId", "front", "back", "createdAt"]
    }
  },
  "firestore": {
    "/subjects/{subjectId}": {
      "schema": "Subject",
      "description": "Curriculum subjects."
    },
    "/users/{userId}": {
      "schema": "User",
      "description": "User profile and progress data."
    },
    "/ratings/{ratingId}": {
      "schema": "SubjectRating",
      "description": "Collection of all subject ratings."
    },
    "/studyGroups/{groupId}": {
      "schema": "StudyGroup",
      "description": "Collaborative study circles."
    },
    "/questions/{questionId}": {
      "schema": "Question",
      "description": "Peer Q&A platform."
    },
    "/notebooks/{notebookId}": {
      "schema": "Notebook",
      "description": "Notebook collections."
    },
    "/notebooks/{notebookId}/sources/{sourceId}": {
      "schema": "NotebookSource",
      "description": "Sources within a notebook."
    },
    "/notebooks/{notebookId}/messages/{messageId}": {
      "schema": "NotebookMessage",
      "description": "Chat messages within a notebook."
    },
    "/flashcardDecks/{deckId}": {
      "schema": "FlashcardDeck",
      "description": "User created flashcard decks."
    },
    "/flashcardDecks/{deckId}/cards/{cardId}": {
      "schema": "Flashcard",
      "description": "Individual flashcards within a deck."
    }
  }
}
