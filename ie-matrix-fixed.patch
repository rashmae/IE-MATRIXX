+/* ============================================
+   IE MATRIX - OPTIMIZATION & PERFORMANCE CSS
+   ============================================ */
+
+/* Smooth scrolling & reduced motion support */
+@media (prefers-reduced-motion: no-preference) {
+  html { scroll-behavior: smooth; }
+}
+@media (prefers-reduced-motion: reduce) {
+  *, *::before, *::after {
+    animation-duration: 0.01ms !important;
+    animation-iteration-count: 1 !important;
+    transition-duration: 0.01ms !important;
+  }
+}
+
+/* Optimized custom scrollbar */
+.custom-scrollbar {
+  scrollbar-width: thin;
+  scrollbar-color: var(--color-ctu-gold) transparent;
+}
+.custom-scrollbar::-webkit-scrollbar { width: 4px; height: 4px; }
+.custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
+.custom-scrollbar::-webkit-scrollbar-thumb {
+  background: var(--color-ctu-gold);
+  border-radius: 999px;
+  opacity: 0.5;
+}
+
+/* No scrollbar utility */
+.no-scrollbar { scrollbar-width: none; -ms-overflow-style: none; }
+.no-scrollbar::-webkit-scrollbar { display: none; }
+
+/* Safe area for mobile (notch support) */
+.safe-bottom { padding-bottom: max(1rem, env(safe-area-inset-bottom)); }
+.safe-top { padding-top: max(1rem, env(safe-area-inset-top)); }
+
+/* Touch-friendly tap targets */
+.tap-target { min-height: 44px; min-width: 44px; }
+
+/* GPU-accelerated transitions */
+.gpu { transform: translateZ(0); will-change: transform; }
+
+/* Responsive text clamp */
+.text-clamp-1 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 1; -webkit-box-orient: vertical; }
+.text-clamp-2 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; }
+.text-clamp-3 { overflow: hidden; display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; }
+
+/* Skeleton loading animation */
+@keyframes skeleton-pulse {
+  0%, 100% { opacity: 0.4; }
+  50% { opacity: 0.8; }
+}
+.skeleton {
+  background: linear-gradient(90deg, var(--color-foreground)/5, var(--color-foreground)/10, var(--color-foreground)/5);
+  background-size: 200% 100%;
+  animation: skeleton-shimmer 1.5s ease-in-out infinite;
+  border-radius: 0.5rem;
+}
+@keyframes skeleton-shimmer {
+  0% { background-position: 200% 0; }
+  100% { background-position: -200% 0; }
+}
+
+/* Focus ring for keyboard nav */
+.focus-ring:focus-visible {
+  outline: 2px solid var(--color-ctu-gold);
+  outline-offset: 2px;
+  border-radius: 0.5rem;
+}
+
+/* Responsive grid helpers */
+.auto-grid-sm { grid-template-columns: repeat(auto-fill, minmax(min(100%, 280px), 1fr)); }
+.auto-grid-md { grid-template-columns: repeat(auto-fill, minmax(min(100%, 320px), 1fr)); }
+.auto-grid-lg { grid-template-columns: repeat(auto-fill, minmax(min(100%, 380px), 1fr)); }
+
+/* Prevent text size adjust on mobile */
+html { -webkit-text-size-adjust: 100%; text-size-adjust: 100%; }
+
+/* Image optimization */
+img { content-visibility: auto; }
+
+/* Print styles */
+@media print {
+  .no-print { display: none !important; }
+  .BottomNav, aside { display: none !important; }
+}
+
+/* High contrast mode support */
+@media (forced-colors: active) {
+  .neumorphic-card, .neumorphic-raised, .neumorphic-pressed {
+    border: 1px solid ButtonText;
+  }
+}
+
+/* Card hover elevation */
+.card-hover {
+  transition: transform 0.2s ease, box-shadow 0.2s ease;
+}
+.card-hover:hover {
+  transform: translateY(-2px);
+}
+
+/* Pulse dot indicator */
+.pulse-dot::before {
+  content: '';
+  position: absolute;
+  top: 0; right: 0;
+  width: 8px; height: 8px;
+  border-radius: 50%;
+  background: var(--color-ctu-gold);
+  animation: pulse-ring 2s cubic-bezier(0.455, 0.03, 0.515, 0.955) infinite;
+}
+@keyframes pulse-ring {
+  0% { transform: scale(1); opacity: 1; }
+  100% { transform: scale(2.5); opacity: 0; }
+}
+
+/* Gradient text */
+.gradient-text {
+  background: linear-gradient(135deg, var(--color-ctu-gold), var(--color-ctu-maroon));
+  -webkit-background-clip: text;
+  -webkit-text-fill-color: transparent;
+  background-clip: text;
+}
+
+/* Responsive container with sensible max-width */
+.content-container {
+  width: 100%;
+  max-width: 1400px;
+  margin: 0 auto;
+  padding: 0 1rem;
+}
+@media (min-width: 640px) { .content-container { padding: 0 1.5rem; } }
+@media (min-width: 1024px) { .content-container { padding: 0 2.5rem; } }
